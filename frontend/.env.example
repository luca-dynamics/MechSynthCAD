# Backend API used by the classic deterministic solver calls.
NEXT_PUBLIC_API_BASE_URL=

# Dev Cloud keys stay server-side in Next API routes. Never expose these with NEXT_PUBLIC_.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional OAuth/account-connection handoff URLs if your deployment provides auth providers.
OPENAI_AUTH_URL=
ANTHROPIC_AUTH_URL=
GEMINI_AUTH_URL=
